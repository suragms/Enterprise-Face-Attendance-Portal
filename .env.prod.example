# ===============================================
# HexaAttender Production Environment Variables Template
# ===============================================
# Copy this file to '.env.prod' and configure credentials before building

# 1. Django Server Configuration
DJANGO_SECRET_KEY=generate-a-secure-random-secret-key-for-production-here-128
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ams.university.edu,127.0.0.1,localhost

# 2. Database Parameters (PostgreSQL Container)
DB_NAME=hexaattender
DB_USER=hexaattender_admin
DB_PASSWORD=secure_database_password_903
DB_HOST=db
DB_PORT=5432
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# 3. Security, CORS & JWT Settings
CORS_ALLOWED_ORIGINS=https://ams.university.edu,http://localhost
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ACCESS_COOKIE_NAME=hexaattender_access
JWT_REFRESH_COOKIE_NAME=hexaattender_refresh

# 4. Notification Providers
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=notifications@example.com
EMAIL_HOST_PASSWORD=replace-with-secure-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=HexaAttender <notifications@example.com>
ADMIN_NOTIFICATION_EMAIL=admin@example.com
SMS_PROVIDER=
WHATSAPP_PROVIDER=

# 5. Optional: SSL Certificates Paths (if mapped inside Nginx proxy)
SSL_CERTIFICATE_PATH=/etc/letsencrypt/live/ams.university.edu/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/ams.university.edu/privkey.pem
